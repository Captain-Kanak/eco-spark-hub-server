model Idea {
    id               String     @id @default(uuid(7))
    title            String     @db.VarChar(255)
    slug             String     @db.VarChar(255)
    coverImage       String?    @db.Text
    description      String     @db.Text
    problemStatement String     @db.Text
    proposedSolution String     @db.Text
    expectedImpact   String     @db.Text
    location         String     @db.Text
    estimatedBudget  Decimal    @default(0)
    fundingGoal      Decimal    @default(0)
    currentFunding   Decimal    @default(0)
    status           IdeaStatus @default(ON_REVIEW)
    views            Int        @default(0)
    userId           String
    user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    categoryId       String
    category         Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    createdAt        DateTime   @default(now())
    updatedAt        DateTime   @updatedAt
    deletedAt        DateTime?

    likes       Like[]
    donations   Donation[]
    ideaUpdates IdeaUpdate[]
    comments    Comment[]

    @@unique([slug])
    @@index([deletedAt])
    @@map("idea")
}

model IdeaUpdate {
    id                 String    @id @default(uuid(7))
    title              String    @db.VarChar(255)
    content            String    @db.Text
    progressPercentage Int       @default(0)
    userId             String
    user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    ideaId             String
    idea               Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
    createdAt          DateTime  @default(now())
    updatedAt          DateTime  @updatedAt
    deletedAt          DateTime?

    ideaUpdateImages IdeaUpdateImage[]

    @@index([deletedAt])
    @@map("idea_update")
}

model IdeaUpdateImage {
    id           String     @id @default(uuid(7))
    imageUrl     String?    @db.Text
    ideaUpdateId String
    ideaUpdate   IdeaUpdate @relation(fields: [ideaUpdateId], references: [id], onDelete: Cascade)
    createdAt    DateTime   @default(now())

    @@index([ideaUpdateId])
    @@map("idea_update_image")
}
