model Category {
    id          String    @id @default(uuid(7))
    name        String    @db.VarChar(255)
    slug        String    @db.VarChar(255)
    icon        String?   @db.Text
    description String?   @db.Text
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    deletedAt   DateTime?

    ideas Idea[]

    @@unique([name])
    @@unique([slug])
    @@index([deletedAt])
    @@map("category")
}
