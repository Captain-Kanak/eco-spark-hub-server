model Category {
    id        String  @id @default(uuid(7))
    name      String  @unique @db.VarChar(100)
    icon      String? @db.Text
    isDeleted Boolean @default(false)

    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    ideas Idea[]

    @@map("categories")
}
